# ─── JobHub Environment Variables ───────────────────────────────────────────
# Copy this to .env.local and fill in values.
# All API keys are optional — the app falls back to mock data if not set.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── JSearch (RapidAPI) ────────────────────────────────────────────────────────
# Aggregates LinkedIn, Indeed, Glassdoor, Naukri in one API.
# Sign up: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 200 requests/month
RAPIDAPI_KEY=

# ── Adzuna ────────────────────────────────────────────────────────────────────
# Free public job API — no credit card required.
# Sign up: https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Remotive ──────────────────────────────────────────────────────────────────
# No key needed. Remote jobs only.
# Docs: https://remotive.com/api/remote-jobs

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Used to extract experience requirements from job descriptions when the
# job platform doesn't provide structured experience data.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
